{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "FlightDex": "Data Source=flightdex.db",
    "Booking": "Data Source=flightdex-booking.db"
  },
  "Cors": {
    "AngularOrigins": [ "http://localhost:4200" ]
  },
  "Jwt": {
    "Issuer": "FlightDex",
    "Audience": "FlightDexClient",
    "Key": "change-me-in-production-with-a-long-random-secret",
    "ExpiryMinutes": 60
  }
}
