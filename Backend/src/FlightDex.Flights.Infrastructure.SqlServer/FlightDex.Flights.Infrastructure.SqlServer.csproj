<Project Sdk="Microsoft.NET.Sdk">

  <!-- Holds the SQL Server (Azure SQL) migrations for FlightsDbContext, in a separate assembly
       from the SQLite migrations so EF doesn't see two ModelSnapshots for one context.
       Selected at runtime via MigrationsAssembly() when Database:Provider=SqlServer. -->

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\FlightDex.Flights.Infrastructure\FlightDex.Flights.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="10.0.0" />
  </ItemGroup>

</Project>
